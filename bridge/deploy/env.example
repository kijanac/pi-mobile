# pi-bridge environment file.
#
# Copy this to /etc/pi-bridge/env on the server, fill in the secrets,
# then chmod 600 + chown root:pi-bridge. systemd reads it via the
# EnvironmentFile= directive in pi-bridge.service.
#
# The unit file owns bridge runtime paths, listener, HOME, and NODE_ENV.
#
# Authentication options:
#   1. Preferred for subscription accounts: SSH to the server and run pi /login
#      as the pi-bridge user so credentials are stored under
#      /var/lib/pi-bridge/.pi/agent/auth.json.
#   2. API-key mode: uncomment one of the provider env vars below.
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Bridge access control. Production requires Tailscale Serve identity headers
# on all non-health requests. On first successful setup from the mobile app,
# the bridge claims that Tailscale login as its owner in the bridge database.
#
# Release updater. Auto-update uses GitHub Releases, a signed manifest,
# versioned installs under /opt/pi-mobile-workspace/releases, and rollback.
# The installer writes PI_BRIDGE_AUTO_UPDATE when auto-update is enabled.
#
# Effect log level: silent | error | warning | info | debug | trace
# EFFECT_LOG_LEVEL=info
